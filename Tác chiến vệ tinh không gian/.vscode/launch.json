#include <GL/freeglut.h>
#include <cmath>
#include <vector>
#include <string>
#include <sstream>
#include <cstdlib>
#include <ctime>
#include <algorithm>

struct Vec2 {
    float x, y;
};

struct Star {
    float x, y;
    float phase;
    float twinkle;
};

struct TrailPoint {
    Vec2 pos;
    float life;
};

enum SatelliteType {
    SAT_RECON = 0,
    SAT_DEFENSE = 1,
    SAT_COMMAND = 2
};

enum MissileType {
    MISSILE_INTERCEPTOR = 0,
    MISSILE_BALLISTIC = 1,
    MISSILE_HUNTER = 2
};

enum GuidanceType {
    GUIDE_DIRECT = 0,
    GUIDE_PARABOLIC = 1,
    GUIDE_HOMING = 2
};

struct SatelliteProfile {
    std::string name;
    std::string role;
    float energy;
    float lockRange;
    float reloadTime;
    float bodyScale;
};

struct MissileProfile {
    std::string name;
    std::string note;
    float speed;
    float turnRate;
    float blastRadius;
    GuidanceType guidance;
    float gravity;
};

struct Target {
    Vec2 pos;
    Vec2 basePos;
    float radius;
    float phase;
    float pulse;
    bool destroyed = false;
};

struct Missile {
    Vec2 pos;
    Vec2 vel;
    Vec2 startPos;
    Vec2 targetSnapshot;
    bool active = false;
    float radius = 6.0f;
    float age = 0.0f;
    float life = 0.0f;
    MissileType type = MISSILE_INTERCEPTOR;
};

struct Explosion {
    Vec2 pos;
    float radius = 0.0f;
    bool active = false;
    int life = 0;
};

const int WIDTH = 1280;
const int HEIGHT = 760;
const float PI = 3.1415926535f;

std::vector<Star> stars;
std::vector<Target> targets;
std::vector<TrailPoint> trail;
Missile missile;
Explosion explosion;

SatelliteType currentSatellite = SAT_RECON;
MissileType currentMissile = MISSILE_INTERCEPTOR;
int selectedTarget = -1;
bool paused = false;
int score = 0;
float globalTimeSec = 0.0f;
float radarSweepAngle = 0.0f;
float cooldown = 0.0f;

SatelliteProfile satProfiles[3] = {
    {"RECON SAT",   "Trinh sat - khoa muc tieu nhanh", 100.0f, 1200.0f, 0.8f, 1.00f},
    {"DEFENSE SAT", "Tac chien - can bang",            120.0f, 1000.0f, 1.2f, 1.15f},
    {"COMMAND SAT", "Chi huy - nang luong cao",        150.0f, 1350.0f, 1.5f, 1.30f}
};

MissileProfile missileProfiles[3] = {
    {"INTERCEPTOR", "Dan danh chan toc do cao",         7.8f, 0.06f, 22.0f, GUIDE_DIRECT,    0.00f},
    {"BALLISTIC",   "Dan dao bay parabol",              7.0f, 0.00f, 32.0f, GUIDE_PARABOLIC, 0.055f},
    {"HUNTER",      "Dan tu dan huong thong minh",      5.8f, 0.14f, 26.0f, GUIDE_HOMING,    0.00f}
};

float randFloat(float a, float b) {
    return a + (b - a) * (float)std::rand() / (float)RAND_MAX;
}

float clampf(float v, float a, float b) {
    return std::max(a, std::min(b, v));
}

float distance2D(const Vec2& a, const Vec2& b) {
    float dx = a.x - b.x;
    float dy = a.y - b.y;
    return std::sqrt(dx * dx + dy * dy);
}

Vec2 normalize(const Vec2& v) {
    float len = std::sqrt(v.x * v.x + v.y * v.y);
    if (len < 0.0001f) return {0.0f, 0.0f};
    return {v.x / len, v.y / len};
}

Vec2 operator+(const Vec2& a, const Vec2& b) { return {a.x + b.x, a.y + b.y}; }
Vec2 operator-(const Vec2& a, const Vec2& b) { return {a.x - b.x, a.y - b.y}; }
Vec2 operator*(const Vec2& a, float k) { return {a.x * k, a.y * k}; }

void drawText(float x, float y, const std::string& text, void* font = GLUT_BITMAP_HELVETICA_18) {
    glRasterPos2f(x, y);
    for (char c : text) glutBitmapCharacter(font, c);
}

void drawCircle(float cx, float cy, float r, int segments = 48, bool filled = true) {
    glBegin(filled ? GL_POLYGON : GL_LINE_LOOP);
    for (int i = 0; i < segments; i++) {
        float angle = 2.0f * PI * i / segments;
        glVertex2f(cx + std::cos(angle) * r, cy + std::sin(angle) * r);
    }
    glEnd();
}

void drawRoundedPanel(float x1, float y1, float x2, float y2, float r) {
    glBegin(GL_QUADS);
    glVertex2f(x1 + r, y1);
    glVertex2f(x2 - r, y1);
    glVertex2f(x2 - r, y2);
    glVertex2f(x1 + r, y2);

    glVertex2f(x1, y1 + r);
    glVertex2f(x1 + r, y1 + r);
    glVertex2f(x1 + r, y2 - r);
    glVertex2f(x1, y2 - r);

    glVertex2f(x2 - r, y1 + r);
    glVertex2f(x2, y1 + r);
    glVertex2f(x2, y2 - r);
    glVertex2f(x2 - r, y2 - r);
    glEnd();

    drawCircle(x1 + r, y1 + r, r, 20, true);
    drawCircle(x2 - r, y1 + r, r, 20, true);
    drawCircle(x1 + r, y2 - r, r, 20, true);
    drawCircle(x2 - r, y2 - r, r, 20, true);
}

void drawBackground() {
    glBegin(GL_QUADS);
    glColor3f(0.01f, 0.01f, 0.04f);
    glVertex2f(0, HEIGHT);
    glVertex2f(WIDTH, HEIGHT);
    glColor3f(0.02f, 0.04f, 0.10f);
    glVertex2f(WIDTH, 0);
    glVertex2f(0, 0);
    glEnd();
}

void drawStars() {
    glPointSize(2.0f);
    glBegin(GL_POINTS);
    for (const auto& s : stars) {
        float a = 0.4f + 0.6f * std::sin(globalTimeSec * s.twinkle + s.phase);
        glColor3f(a, a, a);
        glVertex2f(s.x, s.y);
    }
    glEnd();
}

void drawRadar() {
    glColor3f(0.03f, 0.08f, 0.10f);
    drawRoundedPanel(20, 170, 390, 650, 18);

    glColor3f(0.0f, 0.22f, 0.14f);
    drawCircle(205, 410, 170, 100, false);
    drawCircle(205, 410, 130, 100, false);
    drawCircle(205, 410, 90, 100, false);
    drawCircle(205, 410, 50, 100, false);

    glBegin(GL_LINES);
    glVertex2f(40, 410); glVertex2f(370, 410);
    glVertex2f(205, 245); glVertex2f(205, 575);
    glEnd();

    float ang = radarSweepAngle * PI / 180.0f;
    glColor4f(0.0f, 0.95f, 0.45f, 0.16f);
    glBegin(GL_TRIANGLES);
    glVertex2f(205, 410);
    glVertex2f(205 + std::cos(ang - 0.16f) * 165.0f, 410 + std::sin(ang - 0.16f) * 165.0f);
    glVertex2f(205 + std::cos(ang + 0.16f) * 165.0f, 410 + std::sin(ang + 0.16f) * 165.0f);
    glEnd();

    glColor3f(0.0f, 1.0f, 0.50f);
    glBegin(GL_LINES);
    glVertex2f(205, 410);
    glVertex2f(205 + std::cos(ang) * 165.0f, 410 + std::sin(ang) * 165.0f);
    glEnd();

    drawText(55, 620, "RADAR / THEATER VIEW");
}

Vec2 getSatellitePos() {
    switch (currentSatellite) {
        case SAT_RECON: return {470.0f, 560.0f};
        case SAT_DEFENSE: return {470.0f, 380.0f};
        case SAT_COMMAND: return {470.0f, 210.0f};
    }
    return {470.0f, 380.0f};
}

void drawSatelliteBody(const Vec2& pos, SatelliteType type, bool active) {
    float scale = satProfiles[type].bodyScale;
    glPushMatrix();
    glTranslatef(pos.x, pos.y, 0);
    glScalef(scale, scale, 1.0f);

    if (active) glColor3f(0.82f, 0.86f, 0.95f);
    else glColor3f(0.45f, 0.48f, 0.58f);

    glBegin(GL_QUADS);
    glVertex2f(-20, -12);
    glVertex2f(20, -12);
    glVertex2f(20, 12);
    glVertex2f(-20, 12);
    glEnd();

    if (type == SAT_RECON) glColor3f(0.22f, 0.7f, 1.0f);
    if (type == SAT_DEFENSE) glColor3f(0.35f, 1.0f, 0.45f);
    if (type == SAT_COMMAND) glColor3f(1.0f, 0.7f, 0.22f);

    glBegin(GL_QUADS);
    glVertex2f(-62, -8);
    glVertex2f(-26, -8);
    glVertex2f(-26, 8);
    glVertex2f(-62, 8);

    glVertex2f(26, -8);
    glVertex2f(62, -8);
    glVertex2f(62, 8);
    glVertex2f(26, 8);
    glEnd();

    glColor3f(0.95f, 0.75f, 0.12f);
    drawCircle(0, 0, 7, 24, true);

    if (active) {
        glColor3f(0.95f, 0.2f, 0.2f);
        drawCircle(0, 0, 28, 36, false);
    }

    glPopMatrix();
}

void drawSatelliteDeck() {
    glColor3f(0.03f, 0.08f, 0.12f);
    drawRoundedPanel(410, 120, 690, 650, 18);
    drawText(445, 620, "SATELLITE ARRAY");

    drawSatelliteBody({470, 560}, SAT_RECON, currentSatellite == SAT_RECON);
    drawText(525, 558, "1 - RECON SAT");
    drawText(525, 538, "Khoa muc tieu nhanh");

    drawSatelliteBody({470, 380}, SAT_DEFENSE, currentSatellite == SAT_DEFENSE);
    drawText(525, 378, "2 - DEFENSE SAT");
    drawText(525, 358, "Tac chien can bang");

    drawSatelliteBody({470, 210}, SAT_COMMAND, currentSatellite == SAT_COMMAND);
    drawText(525, 208, "3 - COMMAND SAT");
    drawText(525, 188, "Chi huy / nang luong cao");
}

void drawTarget(const Target& t, bool selected) {
    if (t.destroyed) {
        glColor3f(0.35f, 0.35f, 0.40f);
        drawCircle(t.pos.x, t.pos.y, t.radius, 36, true);
        return;
    }

    float p = 0.5f + 0.5f * std::sin(globalTimeSec * 4.6f + t.pulse);
    glColor3f(1.0f, 0.22f + 0.25f * p, 0.18f);
    drawCircle(t.pos.x, t.pos.y, t.radius, 36, true);
    glColor3f(0.12f, 0.0f, 0.0f);
    drawCircle(t.pos.x, t.pos.y, t.radius * 0.35f, 24, true);

    if (selected) {
        glColor3f(1.0f, 0.0f, 0.0f);
        drawCircle(t.pos.x, t.pos.y, t.radius + 12 + 4 * p, 40, false);
        glBegin(GL_LINES);
        glVertex2f(t.pos.x - 30, t.pos.y); glVertex2f(t.pos.x - 12, t.pos.y);
        glVertex2f(t.pos.x + 12, t.pos.y); glVertex2f(t.pos.x + 30, t.pos.y);
        glVertex2f(t.pos.x, t.pos.y - 30); glVertex2f(t.pos.x, t.pos.y - 12);
        glVertex2f(t.pos.x, t.pos.y + 12); glVertex2f(t.pos.x, t.pos.y + 30);
        glEnd();
    }
}

void drawTargets() {
    for (size_t i = 0; i < targets.size(); i++) {
        drawTarget(targets[i], (int)i == selectedTarget);
    }
}

void drawMissileTrail() {
    for (const auto& p : trail) {
        float r = 2.0f + p.life * 3.5f;
        glColor3f(1.0f, 0.45f + p.life * 0.45f, 0.12f);
        drawCircle(p.pos.x, p.pos.y, r, 20, false);
    }
}

void drawMissile() {
    if (!missile.active) return;
    glPushMatrix();
    glTranslatef(missile.pos.x, missile.pos.y, 0);

    float angle = std::atan2(missile.vel.y, missile.vel.x) * 180.0f / PI;
    glRotatef(angle, 0, 0, 1);

    if (missile.type == MISSILE_INTERCEPTOR) glColor3f(0.92f, 0.95f, 1.0f);
    if (missile.type == MISSILE_BALLISTIC)   glColor3f(1.0f, 0.84f, 0.25f);
    if (missile.type == MISSILE_HUNTER)      glColor3f(0.45f, 1.0f, 0.55f);

    glBegin(GL_TRIANGLES);
    glVertex2f(15, 0);
    glVertex2f(-10, 6);
    glVertex2f(-10, -6);
    glEnd();

    glBegin(GL_QUADS);
    glVertex2f(-3, -3);
    glVertex2f(8, -3);
    glVertex2f(8, 3);
    glVertex2f(-3, 3);
    glEnd();

    glColor3f(1.0f, 0.55f, 0.08f);
    glBegin(GL_TRIANGLES);
    glVertex2f(-10, 0);
    glVertex2f(-24, 5);
    glVertex2f(-24, -5);
    glEnd();

    glPopMatrix();
}

void drawExplosion() {
    if (!explosion.active) return;
    float inner = explosion.radius * 0.45f;
    glColor3f(1.0f, 0.45f, 0.0f);
    drawCircle(explosion.pos.x, explosion.pos.y, explosion.radius, 50, false);
    glColor3f(1.0f, 0.9f, 0.0f);
    drawCircle(explosion.pos.x, explosion.pos.y, inner, 40, false);

    glBegin(GL_LINES);
    for (int i = 0; i < 14; i++) {
        float a = 2.0f * PI * i / 14.0f;
        glVertex2f(explosion.pos.x + std::cos(a) * inner, explosion.pos.y + std::sin(a) * inner);
        glVertex2f(explosion.pos.x + std::cos(a) * explosion.radius, explosion.pos.y + std::sin(a) * explosion.radius);
    }
    glEnd();
}

