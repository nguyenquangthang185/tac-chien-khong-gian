void display() {
    glClear(GL_COLOR_BUFFER_BIT);
    drawBackground();
    drawStars();
    drawRadar();
    drawSatelliteDeck();
    drawTargets();
    drawMissileTrail();
    drawMissile();
    drawExplosion();
    drawMissilePanel();
    drawStatusPanel();
    drawHelpBar();
    glutSwapBuffers();
}

void initStars() {
    stars.clear();
    for (int i = 0; i < 140; i++) {
        stars.push_back({
            randFloat(0.0f, (float)WIDTH),
            randFloat(0.0f, (float)HEIGHT),
            randFloat(0.0f, 6.28f),
            randFloat(0.8f, 3.5f)
        });
    }
}

void resetTargets() {
    targets.clear();
    targets.push_back({{820, 560}, {820, 560}, 24, 0.2f, 0.2f, false});
    targets.push_back({{1120, 520}, {1120, 520}, 22, 1.1f, 1.0f, false});
    targets.push_back({{980, 340}, {980, 340}, 20, 2.4f, 2.2f, false});
    targets.push_back({{820, 200}, {820, 200}, 26, 3.0f, 0.8f, false});
    targets.push_back({{1110, 220}, {1110, 220}, 18, 4.0f, 1.7f, false});
}

void resetGame() {
    resetTargets();
    missile = Missile();
    explosion = Explosion();
    trail.clear();
    selectedTarget = -1;
    paused = false;
    score = 0;
    cooldown = 0.0f;
}

bool targetInRange(int idx) {
    if (idx < 0 || idx >= (int)targets.size()) return false;
    Vec2 satPos = getSatellitePos();
    return distance2D(satPos, targets[idx].pos) <= satProfiles[currentSatellite].lockRange;
}

void launchMissile() {
    if (selectedTarget < 0) return;
    if (targets[selectedTarget].destroyed) return;
    if (missile.active) return;
    if (cooldown > 0.0f) return;
    if (!targetInRange(selectedTarget)) return;

    Vec2 satPos = getSatellitePos();
    const MissileProfile& mp = missileProfiles[currentMissile];

    missile.active = true;
    missile.type = currentMissile;
    missile.pos = satPos;
    missile.startPos = satPos;
    missile.targetSnapshot = targets[selectedTarget].pos;
    missile.radius = 6.0f;
    missile.age = 0.0f;
    missile.life = 0.0f;

    Vec2 dir = normalize(missile.targetSnapshot - satPos);
    missile.vel = dir * mp.speed;

    if (mp.guidance == GUIDE_PARABOLIC) {
        float dx = missile.targetSnapshot.x - satPos.x;
        float dy = missile.targetSnapshot.y - satPos.y;
        float flightTime = std::max(0.8f, std::fabs(dx) / std::max(1.0f, mp.speed * 55.0f));
        missile.vel.x = dx / (flightTime * 60.0f);
        missile.vel.y = (dy / (flightTime * 60.0f)) + mp.gravity * flightTime * 30.0f;
    }

    trail.clear();
    cooldown = satProfiles[currentSatellite].reloadTime;
}

void updateTargets(float dt) {
    for (size_t i = 0; i < targets.size(); i++) {
        if (targets[i].destroyed) continue;
        float ampX = 22.0f + i * 5.0f;
        float ampY = 15.0f + i * 4.0f;
        targets[i].pos.x = targets[i].basePos.x + std::cos(globalTimeSec * 0.85f + targets[i].phase) * ampX;
        targets[i].pos.y = targets[i].basePos.y + std::sin(globalTimeSec * 1.15f + targets[i].phase) * ampY;
    }
}

void updateTrail(float dt) {
    for (auto& p : trail) p.life -= dt * 1.5f;
    trail.erase(std::remove_if(trail.begin(), trail.end(), [](const TrailPoint& p) {
        return p.life <= 0.0f;
    }), trail.end());
}

void explodeAt(const Vec2& pos, float radiusBonus) {
    explosion.active = true;
    explosion.pos = pos;
    explosion.radius = 12.0f + radiusBonus * 0.15f;
    explosion.life = 26;
}

void checkHit() {
    if (!missile.active) return;
    const MissileProfile& mp = missileProfiles[missile.type];

    for (size_t i = 0; i < targets.size(); i++) {
        if (targets[i].destroyed) continue;
        float d = distance2D(missile.pos, targets[i].pos);
        if (d <= targets[i].radius + mp.blastRadius * 0.35f) {
            explodeAt(targets[i].pos, mp.blastRadius);

            for (auto& t : targets) {
                if (!t.destroyed && distance2D(t.pos, targets[i].pos) <= mp.blastRadius) {
                    t.destroyed = true;
                    score += 10;
                }
            }

            missile.active = false;
            selectedTarget = -1;
            return;
        }
    }
}

void updateMissile(float dt) {
    if (!missile.active) return;

    missile.age += dt;
    missile.life += dt;
    const MissileProfile& mp = missileProfiles[missile.type];

    if (mp.guidance == GUIDE_DIRECT) {
        missile.pos = missile.pos + missile.vel;
    }
    else if (mp.guidance == GUIDE_PARABOLIC) {
        missile.vel.y -= mp.gravity;
        missile.pos = missile.pos + missile.vel;
    }
    else if (mp.guidance == GUIDE_HOMING) {
        Vec2 targetPos = missile.targetSnapshot;
        if (selectedTarget >= 0 && !targets[selectedTarget].destroyed) {
            targetPos = targets[selectedTarget].pos;
        } else {
            float best = 1e9f;
            for (const auto& t : targets) {
                if (t.destroyed) continue;
                float d = distance2D(missile.pos, t.pos);
                if (d < best) {
                    best = d;
                    targetPos = t.pos;
                }
            }
        }

        Vec2 desired = normalize(targetPos - missile.pos);
        Vec2 cur = normalize(missile.vel);
        Vec2 blended = normalize(cur * (1.0f - mp.turnRate) + desired * mp.turnRate);
        missile.vel = blended * mp.speed;
        missile.pos = missile.pos + missile.vel;
    }

    trail.push_back({missile.pos, 1.0f});
    if (trail.size() > 34) trail.erase(trail.begin());

    checkHit();

    if (missile.pos.x < -50 || missile.pos.x > WIDTH + 50 || missile.pos.y < -50 || missile.pos.y > HEIGHT + 50) {
        missile.active = false;
    }
    if (missile.life > 8.0f) {
        missile.active = false;
    }
}

void updateExplosion() {
    if (!explosion.active) return;
    explosion.radius += 4.2f;
    explosion.life--;
    if (explosion.life <= 0) {
        explosion.active = false;
        explosion.radius = 0.0f;
    }
}

void timer(int value) {
    const float dt = 0.016f;
    if (!paused) {
        globalTimeSec += dt;
        radarSweepAngle += 2.4f;
        if (radarSweepAngle > 360.0f) radarSweepAngle -= 360.0f;
        updateTargets(dt);
        updateMissile(dt);
        updateExplosion();
        updateTrail(dt);
        if (cooldown > 0.0f) cooldown = std::max(0.0f, cooldown - dt);
    }

    glutPostRedisplay();
    glutTimerFunc(16, timer, 0);
}

void mouse(int button, int state, int x, int y) {
    if (button != GLUT_LEFT_BUTTON || state != GLUT_DOWN) return;
    float mx = (float)x;
    float my = (float)(HEIGHT - y);

    selectedTarget = -1;
    for (size_t i = 0; i < targets.size(); i++) {
        if (targets[i].destroyed) continue;
        if (distance2D({mx, my}, targets[i].pos) <= targets[i].radius + 10.0f) {
            selectedTarget = (int)i;
            break;
        }
    }

    glutPostRedisplay();
}

void keyboard(unsigned char key, int, int) {
    switch (key) {
        case '1': currentSatellite = SAT_RECON; break;
        case '2': currentSatellite = SAT_DEFENSE; break;
        case '3': currentSatellite = SAT_COMMAND; break;

        case 'q': case 'Q': currentMissile = MISSILE_INTERCEPTOR; break;
        case 'w': case 'W': currentMissile = MISSILE_BALLISTIC; break;
        case 'e': case 'E': currentMissile = MISSILE_HUNTER; break;

        case 32: launchMissile(); break;
        case 'r': case 'R': resetGame(); break;
        case 'p': case 'P': paused = !paused; break;
        case 27: std::exit(0); break;
    }
}

void init() {
    std::srand((unsigned)std::time(nullptr));
    glClearColor(0.02f, 0.02f, 0.05f, 1.0f);
    glMatrixMode(GL_PROJECTION);
    glLoadIdentity();
    gluOrtho2D(0, WIDTH, 0, HEIGHT);

    initStars();
    resetGame();
}

int main(int argc, char** argv) {
    glutInit(&argc, argv);
    glutInitDisplayMode(GLUT_DOUBLE | GLUT_RGB);
    glutInitWindowSize(WIDTH, HEIGHT);
    glutInitWindowPosition(40, 20);
    glutCreateWindow("Mo phong he thong tac chien ve tinh 2D - Professional Simulation");

    init();
    glutDisplayFunc(display);
    glutKeyboardFunc(keyboard);
    glutMouseFunc(mouse);
    glutTimerFunc(16, timer, 0);
    glutMainLoop();
    return 0;
}
