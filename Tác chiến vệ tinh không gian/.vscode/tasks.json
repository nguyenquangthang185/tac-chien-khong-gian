{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-opengl",
      "type": "shell",
      "command": "g++",
      "args": [
        "main.cpp",
        "-o",
        "satellite_sim.exe",
        "-Ifreeglut/include",
        "-Lfreeglut/lib",
        "-lfreeglut",
        "-lopengl32",
        "-lglu32",
        "-Wall"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}